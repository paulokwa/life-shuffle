rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasMemberList(data) {
      return data.memberUserIds is list;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerUserId == request.auth.uid;
    }

    function isMember(data) {
      return isSignedIn() &&
        hasMemberList(data) &&
        data.memberUserIds.hasAny([request.auth.uid]);
    }

    function isOwnDefaultCalendarPath(calendarId) {
      return isSignedIn() && calendarId == request.auth.uid + '_default';
    }

    function keepsCalendarIdentity(data) {
      return request.resource.data.ownerUserId == data.ownerUserId &&
        request.resource.data.calendarId == data.calendarId;
    }

    function keepsMembersOrIsOwner(data) {
      return isOwner(data) ||
        request.resource.data.memberUserIds == data.memberUserIds;
    }

    function isOwnProfile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /calendars/{calendarId} {
      // MVP owner/member access only. This is not final invite or role logic.
      allow read: if isOwner(resource.data) ||
        isMember(resource.data) ||
        isOwnDefaultCalendarPath(calendarId);

      allow create: if isSignedIn() &&
        request.resource.data.calendarId == calendarId &&
        request.resource.data.ownerUserId == request.auth.uid &&
        hasMemberList(request.resource.data) &&
        request.resource.data.memberUserIds.hasAny([request.auth.uid]);

      allow update: if (isOwner(resource.data) || isMember(resource.data)) &&
        keepsCalendarIdentity(resource.data) &&
        keepsMembersOrIsOwner(resource.data);
    }

    match /userProfiles/{userId} {
      // Minimal private-app lookup profile. Do not store secrets or broad
      // public profile data here.
      allow read: if isSignedIn();

      allow create, update: if isOwnProfile(userId) &&
        request.resource.data.uid == userId;
    }
  }
}
